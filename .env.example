# ======================================================================
# DOC-007-AI Environment Variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# ======================================================================

# ---- App ----
ENVIRONMENT=development
DEBUG=true
APP_NAME=DOC-007-AI

# ---- Security ----
# Generate a strong secret, e.g.:  openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:3000

# ---- Postgres ----
POSTGRES_USER=doc007
POSTGRES_PASSWORD=doc007
POSTGRES_DB=doc007
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async SQLAlchemy URL (used by the API + Alembic). Host = service name in docker-compose.
DATABASE_URL=postgresql+asyncpg://doc007:doc007@postgres:5432/doc007

# ---- Redis (Celery broker + result backend + cache/rate-limit) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Qdrant (vector store) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=doc_chunks
# Must match the embedding model's output dimension. text-embedding-3-small = 1536.
VECTOR_DIM=1536

# ---- AI providers (SERVER-SIDE ONLY, never exposed to the frontend) ----
# LLM via OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# Embeddings via OpenAI
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ---- RAG tuning ----
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=80
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.25

# ---- Storage (local volume now; S3-compatible later) ----
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/uploads
MAX_UPLOAD_MB=25

# ---- OAuth / SSO (optional; a provider shows up only when both values are set) ----
# Register an OAuth app and add the redirect URI http://localhost:3000/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub redirect URI: http://localhost:3000/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Frontend (public; safe to expose) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
